FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

# Download XtraBackup 8.0.35 (for MySQL 8.0.x)
RUN apt-get update && apt-get install -y wget && rm -rf /var/lib/apt/lists/*
RUN wget -q https://downloads.percona.com/downloads/Percona-XtraBackup-80/Percona-XtraBackup-8.0.35/binary/debian/ubuntu22.04/x86_64/percona-xtrabackup-80
_8.0.35-30.jammy.x86_64.deb

# Download missing dependencies (libev4, libsnappy1v5)
RUN apt-get update && apt-get download libev4 libsnappy1v5 && rm -rf /var/lib/apt/lists/*

# Create archive
RUN tar -zcvf /xtrabackup-packages.tgz .

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]

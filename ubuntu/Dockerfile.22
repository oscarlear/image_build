FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

# 1. 安装基础工具，增加了一个关键工具：grep
RUN apt-get update && apt-get install -y \
    wget \
    gnupg2 \
    lsb-release \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 2. 安装 Percona 仓库
RUN wget -q https://repo.percona.com/apt/percona-release_latest.generic_all.deb -O /tmp/percona-release.deb \
    && apt-get install -y /tmp/percona-release.deb \
    && rm /tmp/percona-release.deb

RUN percona-release enable-only tools release && apt-get update

# 3. 【核心改动】递归获取所有依赖包的名字并下载
# 我们利用 apt-cache depends 找出 xtrabackup 运行需要的所有包，然后传给 apt-get download
RUN apt-get download $(apt-cache depends --recurse --no-recommends --no-suggests \
    percona-xtrabackup-80 | grep "^\s" | sed 's/^[[:space:]]*//; s/<[^>]*>//g' | sort -u) \
    percona-xtrabackup-80

# 4. 打包所有下载下来的 .deb 文件
RUN tar -zcvf /xtrabackup-packages.tgz *.deb

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]

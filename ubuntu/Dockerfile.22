FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

# 1. 安装基础依赖
RUN apt-get update && apt-get install -y \
    wget \
    gnupg2 \
    lsb-release \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 2. 安装 Percona 仓库工具包
RUN wget -q https://repo.percona.com/apt/percona-release_latest.generic_all.deb -O /tmp/percona-release.deb \
    && apt-get install -y ./tmp/percona-release.deb \
    && rm /tmp/percona-release.deb

# 3. 启用 tools 仓库并更新索引 (这步最关键，决定了后面能不能找到包)
RUN percona-release enable-only tools release && apt-get update

# 4. 【核心改动】去掉版本号后缀，只写包名！
# --download-only 会自动把 xtrabackup 及其依赖（perl, libcurl, libev 等）全部下到缓存里
RUN apt-get install --download-only -y percona-xtrabackup-80

# 5. 把下载好的所有 .deb (包含主程序和所有缺失组件) 收集起来打包
RUN cp /var/cache/apt/archives/*.deb . && \
    tar -zcvf /xtrabackup-packages.tgz *.deb

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]

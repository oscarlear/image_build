FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

# 1. 安装系统工具 (加入 curl)
RUN apt-get update && apt-get install -y \
    wget \
    gnupg2 \
    lsb-release \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 2. 安装 Percona 仓库工具 (使用 dpkg -i 替代 apt-get)
RUN wget -q https://repo.percona.com/apt/percona-release_latest.generic_all.deb -O /tmp/percona-release.deb \
    && dpkg -i /tmp/percona-release.deb \
    && apt-get install -f -y \
    && rm /tmp/percona-release.deb

# 3. 启用仓库并更新
RUN percona-release enable-only tools release && apt-get update

# 4. 下载包：使用 download-only 获取包括依赖在内的所有包
# 注意：依然不锁版本号，避免版本找不到的报错
RUN apt-get install --download-only -y percona-xtrabackup-80

# 5. 打包 (收集缓存目录中的所有 .deb，包含依赖)
RUN cp /var/cache/apt/archives/*.deb . && \
    tar -zcvf /xtrabackup-packages.tgz *.deb

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]

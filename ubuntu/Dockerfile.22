FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

# 1. 安装必要的系统工具
RUN apt-get update && apt-get install -y \
    wget \
    gnupg2 \
    lsb-release \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 2. 安装 Percona 仓库配置工具
RUN wget -q https://repo.percona.com/apt/percona-release_latest.generic_all.deb -O /tmp/percona-release.deb \
    && apt-get install -y /tmp/percona-release.deb \
    && rm /tmp/percona-release.deb

# 3. 关键点：启用仓库并让它自动适配你的系统 (Ubuntu 22.04 会自动关联到 jammy 源)
RUN percona-release enable-only tools release && apt-get update

# 4. 下载包：直接下载，apt 会自动根据 Ubuntu 22.04 寻找对应的 .jammy 版本
# 这样你就不用纠结是 focal 还是 jammy 了
RUN apt-get download percona-xtrabackup-80 libev4 libsnappy1v5

# 5. 打包
RUN tar -zcvf /xtrabackup-packages.tgz *.deb

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /export

RUN apt-get update && apt-get install -y wget gnupg2 && rm -rf /var/lib/apt/lists/*
# Download Percona repo package
RUN wget -q https://repo.percona.com/apt/percona-release_latest.generic_all.deb -O /tmp/percona.deb
# Install Percona repo
RUN dpkg -i /tmp/percona.deb && rm /tmp/percona.deb
# Enable xtrabackup repository
RUN percona-release enable-only tools release && apt-get update
# Download XtraBackup and dependencies
RUN apt-get download percona-xtrabackup-80 libev4 libsnappy1v5
# Create archive
RUN tar -zcvf /xtrabackup-packages.tgz *.deb

FROM alpine:3.20
COPY --from=0 /xtrabackup-packages.tgz /packages/
CMD ["tail", "-f", "/dev/null"]
